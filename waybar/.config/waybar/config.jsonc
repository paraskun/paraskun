{
  "height": 30,
  "spacing": 4,

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "memory",
    "cpu",
    "network",
    "hyprland/language"
  ],

  "hyprland/workspaces": {
    "persistent-workspaces": {
      "HDMI-A-1": [1, 2, 3],
      "DP-1": [4, 5, 6]
    },

    "format": "{icon} {name}",

    "format-icons": {
      "active": "",
      "default": ""
    }
  }
}

